<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121826"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="系统配置 (Settings)"
            android:textColor="#00E5FF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- 端口设置 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:text="Server Port"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />

            <EditText
                android:id="@+id/etPort"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#1F2A45"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:padding="10dp" />
        </LinearLayout>

        <!-- 设备名称 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:text="Device Name"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />

            <EditText
                android:id="@+id/etDeviceName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#1F2A45"
                android:inputType="text"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:padding="10dp" />
        </LinearLayout>

        <!-- 开机自启 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:text="Auto Start"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchAutoStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#00E5FF" />
        </LinearLayout>

        <!-- 自动恢复 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:text="Auto Restore"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchAutoRestore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#00E5FF" />
        </LinearLayout>

        <!-- 操作按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnSave"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:backgroundTint="#00E5FF"
                android:textColor="#121826"
                android:text="保存配置"
                android:textSize="16sp"
                android:layout_marginRight="16dp" />

            <Button
                android:id="@+id/btnRestartServer"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:backgroundTint="#FF4081"
                android:textColor="#FFFFFF"
                android:text="重启 HTTP 服务"
                android:textSize="16sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
